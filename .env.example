# The URL for your Postgres + pgvector database
# (If using the provided docker-compose.yml, you can use this exactly)
DATABASE_URL="postgresql+asyncpg://postgres:tiger@localhost:5433/chatdb"

# Your free OpenRouter API Key for background context summarization
ChatSum_API="your_openrouter_api_key_here"

# The master secret key required by external apps (and the Python SDK) to access the engine
APP_API_KEY="your_super_secret_key"
